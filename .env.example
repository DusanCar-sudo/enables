# Enables stores the selected provider in ~/.enables.json.
# Provider keys can also be supplied through environment variables.

DEEPSEEK_API_KEY=sk-your-key-here
XIAOMI_API_KEY=tp-your-token-plan-key-here
MIMO_PAYG_API_KEY=sk-your-payg-key-here
OPENROUTER_API_KEY=sk-or-your-key-here
OPENAI_API_KEY=sk-proj-your-key-here

# Local proxy port defaults to 8080 in the saved config.
